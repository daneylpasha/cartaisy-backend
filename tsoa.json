{
  "entryFile": "src/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": [
    "src/controllers/**/*.ts"
  ],
  "spec": {
    "outputDirectory": "public",
    "specVersion": 3,
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "spec": {
      "info": {
        "title": "Cartaisy API",
        "version": "1.0.0",
        "description": "E-commerce backend API with Shopify integration"
      },
      "servers": [
        {
          "url": "http://localhost:3000/api/v1",
          "description": "Development server"
        }
      ],
      "paths": {
        "/search/suggestions": {
          "get": {
            "responses": {
              "400": {
                "description": "Bad Request"
              },
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        },
        "/search/products": {
          "get": {
            "responses": {
              "400": {
                "description": "Bad Request"
              },
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        },
        "/search/track-click": {
          "post": {
            "responses": {
              "400": {
                "description": "Bad Request"
              },
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        },
        "/search/popular": {
          "get": {
            "responses": {
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        },
        "/search/history": {
          "get": {
            "responses": {
              "401": {
                "description": "Unauthorized"
              },
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        },
        "/search/history/clear": {
          "post": {
            "responses": {
              "401": {
                "description": "Unauthorized"
              },
              "500": {
                "description": "Internal Server Error"
              }
            }
          }
        }
      }
    },
    "specMerging": "deepmerge"
  },
  "routes": {
    "routesDir": "src/generated",
    "middleware": "express",
    "basePath": "/api/v1",
    "authenticationModule": "./src/authentication"
  }
}
