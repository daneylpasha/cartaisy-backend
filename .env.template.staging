# ===============================================
# CARTAISY BACKEND - STAGING ENVIRONMENT
# ===============================================
# This template is for staging/testing environments that mirror production
# Use this for client demos, UAT, and pre-production testing

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment mode - Critical for staging behavior
NODE_ENV=staging

# Server port - Use production-like port
PORT=3000

# Application metadata
APP_NAME=Cartaisy Backend (Staging)
APP_VERSION=1.0.0

# Base URL for staging environment
BASE_URL=https://staging-api.yourdomain.com

# ===============================================
# DATABASE CONFIGURATION
# ===============================================

# MongoDB connection - Use dedicated staging database
# CRITICAL: Never use production database for staging
# Format: mongodb+srv://username:password@staging-cluster.mongodb.net/cartaisy_staging
MONGODB_URI=mongodb+srv://staging_user:SECURE_PASSWORD@staging-cluster.mongodb.net/cartaisy_staging?retryWrites=true&w=majority

# Database connection options (production-like settings)
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Enable database query logging for staging debugging
MONGODB_DEBUG=true

# ===============================================
# AUTHENTICATION & SECURITY
# ===============================================

# JWT Secret - MUST be different from production and development
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_UNIQUE_STAGING_JWT_SECRET_HERE

# JWT expiration settings (can be longer for testing)
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Production-level password hashing
BCRYPT_ROUNDS=12

# Session secret for staging
SESSION_SECRET=GENERATE_UNIQUE_STAGING_SESSION_SECRET

# ===============================================
# CORS & FRONTEND CONFIGURATION
# ===============================================

# Allowed origins for staging frontend
CORS_ORIGINS=https://staging.yourdomain.com,https://staging-admin.yourdomain.com

# Staging frontend URL
FRONTEND_URL=https://staging.yourdomain.com

# Mobile app staging scheme
MOBILE_APP_SCHEME=cartaisy-staging://

# ===============================================
# RATE LIMITING & SECURITY
# ===============================================

# Staging rate limiting (slightly more restrictive than dev)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_ENABLED=true

# Trust proxy for staging load balancer
RATE_LIMIT_TRUST_PROXY=1

# Security headers enforcement
ENABLE_SECURITY_HEADERS=true
ENABLE_CSRF_PROTECTION=true

# ===============================================
# SHOPIFY INTEGRATION
# ===============================================

# Shopify staging/test store credentials
# Use test store for staging environment
SHOPIFY_API_KEY=your_staging_shopify_api_key
SHOPIFY_API_SECRET=your_staging_shopify_api_secret
SHOPIFY_ACCESS_TOKEN=your_staging_access_token

# Staging Shopify store URL
SHOPIFY_STORE_URL=your-staging-store.myshopify.com

# Webhook secret for staging
SHOPIFY_WEBHOOK_SECRET=your_staging_webhook_secret

# Use latest stable API version
SHOPIFY_API_VERSION=2023-10

# Enable Shopify features for testing
ENABLE_SHOPIFY_SYNC=true
SHOPIFY_SYNC_INTERVAL=15

# ===============================================
# EMAIL SERVICE CONFIGURATION
# ===============================================

# Email service for staging (use test/sandbox mode)
EMAIL_SERVICE=sendgrid

# SendGrid staging configuration
SENDGRID_API_KEY=your_staging_sendgrid_api_key
EMAIL_FROM=staging-noreply@yourdomain.com
EMAIL_FROM_NAME=Cartaisy Staging

# Email template IDs for staging
EMAIL_TEMPLATE_WELCOME=d-staging_welcome_template_id
EMAIL_TEMPLATE_PASSWORD_RESET=d-staging_reset_template_id
EMAIL_TEMPLATE_ORDER_CONFIRMATION=d-staging_order_template_id

# Email delivery settings for staging
EMAIL_SEND_REAL_EMAILS=false
EMAIL_TEST_RECIPIENTS=developer@yourdomain.com,qa@yourdomain.com

# ===============================================
# FILE STORAGE & CDN
# ===============================================

# File storage for staging (separate from production)
FILE_STORAGE_PROVIDER=aws-s3

# AWS S3 staging bucket
AWS_ACCESS_KEY_ID=your_staging_aws_access_key
AWS_SECRET_ACCESS_KEY=your_staging_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cartaisy-staging-uploads

# Staging CDN configuration
CDN_URL=https://staging-cdn.yourdomain.com

# File upload limits (can be more generous for testing)
FILE_STORAGE_MAX_SIZE=52428800

# ===============================================
# PAYMENT INTEGRATION
# ===============================================

# Stripe test/sandbox configuration
STRIPE_SECRET_KEY=sk_test_your_staging_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_staging_webhook_secret
STRIPE_API_VERSION=2023-10-16

# PayPal sandbox for staging
PAYPAL_CLIENT_ID=your_staging_paypal_client_id
PAYPAL_CLIENT_SECRET=your_staging_paypal_client_secret
PAYPAL_MODE=sandbox

# ===============================================
# PUSH NOTIFICATIONS
# ===============================================

# Firebase staging project
FCM_SERVER_KEY=your_staging_fcm_server_key
FCM_SENDER_ID=your_staging_fcm_sender_id

# Apple Push Notifications staging
APNS_KEY_ID=your_staging_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_PRIVATE_KEY_PATH=/app/keys/staging_apns_private_key.p8

# Enable push notifications for testing
ENABLE_PUSH_NOTIFICATIONS=true

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Redis staging instance
REDIS_URL=redis://staging-redis.yourdomain.com:6379
REDIS_PASSWORD=your_staging_redis_password
REDIS_DB=0

# Redis connection settings
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_ON_FAILURE=100

# Enable Redis caching for staging
ENABLE_REDIS_CACHE=true

# ===============================================
# LOGGING & MONITORING
# ===============================================

# Staging log level (more verbose than production)
LOG_LEVEL=info

# Enable comprehensive logging for staging debugging
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Sentry staging environment
SENTRY_DSN=your_staging_sentry_dsn
SENTRY_ENVIRONMENT=staging

# Application monitoring for staging
ENABLE_PERFORMANCE_MONITORING=true

# ===============================================
# BACKGROUND JOBS & QUEUES
# ===============================================

# Enable background jobs with Redis
ENABLE_BACKGROUND_JOBS=true
JOB_QUEUE_PROVIDER=redis

# Job processing settings
JOB_CONCURRENCY=4
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY=5000

# ===============================================
# ANALYTICS & TRACKING
# ===============================================

# Google Analytics staging property
GOOGLE_ANALYTICS_ID=GA_STAGING_TRACKING_ID

# Enable analytics for staging testing
ENABLE_ANALYTICS=true

# Custom analytics endpoint for staging
ANALYTICS_ENDPOINT=https://staging-analytics.yourdomain.com

# ===============================================
# FEATURE FLAGS
# ===============================================

# Enable all features for comprehensive staging testing
ENABLE_USER_REGISTRATION=true
ENABLE_GUEST_CHECKOUT=true
ENABLE_PRODUCT_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_MULTI_CURRENCY=true
ENABLE_INVENTORY_TRACKING=true
ENABLE_ORDER_NOTIFICATIONS=true

# Staging-specific feature flags
ENABLE_ADMIN_DEBUG_MODE=true
ENABLE_TEST_DATA_GENERATION=true

# ===============================================
# SSL & SECURITY CONFIGURATION
# ===============================================

# Force HTTPS in staging
FORCE_HTTPS=true

# SSL certificate paths (if using custom certificates)
SSL_CERT_PATH=/app/ssl/staging_cert.pem
SSL_KEY_PATH=/app/ssl/staging_key.pem

# Security headers
HSTS_MAX_AGE=31536000
ENABLE_CONTENT_SECURITY_POLICY=true

# ===============================================
# STAGING-SPECIFIC SETTINGS
# ===============================================

# Enable staging utilities
ENABLE_API_DOCS=true
ENABLE_GRAPHQL_PLAYGROUND=true
ENABLE_SEED_DATA=true

# Database seeding for staging
AUTO_SEED_DATABASE=false
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=SecureAdminPassword123!

# Mock services configuration
MOCK_EXTERNAL_APIS=false
ENABLE_API_SIMULATION_MODE=false

# Performance testing settings
ENABLE_LOAD_TESTING_ENDPOINTS=true
MAX_CONCURRENT_REQUESTS=100

# ===============================================
# HEALTH CHECKS & MONITORING
# ===============================================

# Health check endpoints
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_PATH=/health
DETAILED_HEALTH_CHECK_PATH=/health/detailed

# Monitoring intervals
HEALTH_CHECK_INTERVAL=30000
PERFORMANCE_CHECK_INTERVAL=60000

# Alert thresholds for staging
MEMORY_ALERT_THRESHOLD=80
CPU_ALERT_THRESHOLD=80
RESPONSE_TIME_ALERT_THRESHOLD=2000

# ===============================================
# BACKUP & RECOVERY
# ===============================================

# Automated backup settings for staging
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# Backup storage location
BACKUP_STORAGE_PROVIDER=aws-s3
BACKUP_S3_BUCKET=cartaisy-staging-backups

# ===============================================
# STAGING SECURITY CHECKLIST
# ===============================================

# 1. Use separate database and API keys from production
# 2. Generate unique JWT secrets for staging
# 3. Enable test mode for payment gateways
# 4. Use staging-specific email templates and recipients
# 5. Implement proper SSL certificates
# 6. Configure staging-specific DNS records
# 7. Enable comprehensive logging for debugging
# 8. Use separate file storage buckets
# 9. Configure rate limiting for realistic testing
# 10. Enable security headers and HTTPS enforcement

# ===============================================
# REQUIRED VARIABLES FOR STAGING
# ===============================================

# Critical (application will not start without these):
# - NODE_ENV=staging
# - PORT
# - MONGODB_URI (staging database)
# - JWT_SECRET (unique for staging)
# - BASE_URL (staging domain)

# Important for full functionality:
# - SHOPIFY_* credentials (test store)
# - EMAIL_* configuration (staging/test mode)
# - STRIPE_* credentials (test keys)
# - AWS_* credentials (staging buckets)

# Optional but recommended:
# - REDIS_URL (for caching and jobs)
# - SENTRY_DSN (error tracking)
# - FCM_* (push notification testing)

# ===============================================
# VALIDATION NOTES
# ===============================================

# 1. All secrets must be different from production
# 2. Database must be staging-specific
# 3. Payment gateways must be in test/sandbox mode
# 4. Email services should use test recipients
# 5. File storage must use separate buckets
# 6. SSL certificates should be valid for staging domain
# 7. CORS origins must include staging frontend URLs
# 8. Rate limiting should be production-like but not too restrictive