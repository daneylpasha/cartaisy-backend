# ===============================================
# CARTAISY BACKEND - DEVELOPMENT ENVIRONMENT
# ===============================================
# This template contains all environment variables needed for development
# Copy this file to .env and update the values according to your setup

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment mode - NEVER change this for development
NODE_ENV=development

# Server port - Default development port
# Security: Use non-standard ports in production
PORT=3000

# Application name and version (for logging and monitoring)
APP_NAME=Cartaisy Backend
APP_VERSION=1.0.0

# Base URL for the application (used for CORS and redirects)
BASE_URL=http://localhost:3000

# ===============================================
# DATABASE CONFIGURATION
# ===============================================

# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<database>?options
# For local MongoDB: mongodb://localhost:27017/cartaisy_development
# Security: Use strong passwords and enable authentication even in development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority

# Database connection options
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ===============================================
# AUTHENTICATION & SECURITY
# ===============================================

# JWT Secret - Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# CRITICAL: This must be a strong, random secret in all environments
JWT_SECRET=your-super-secure-jwt-secret-generate-new-one

# JWT token expiration time
# Formats: '1d', '7d', '24h', '3600' (seconds)
JWT_EXPIRES_IN=7d

# JWT Refresh token expiration
JWT_REFRESH_EXPIRES_IN=30d

# Password hashing rounds (higher = more secure but slower)
# Development: 10-12, Production: 12-15
BCRYPT_ROUNDS=10

# Session secret for express-session (if used)
SESSION_SECRET=your-session-secret-here

# ===============================================
# CORS & FRONTEND CONFIGURATION
# ===============================================

# Allowed origins for CORS (comma-separated)
# Development: Allow localhost on various ports
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://localhost:19006

# Frontend application URL (for redirects and email links)
FRONTEND_URL=http://localhost:3001

# Mobile app deep link schemes (for notifications)
MOBILE_APP_SCHEME=cartaisy://

# ===============================================
# RATE LIMITING & SECURITY
# ===============================================

# Rate limiting configuration
# Window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
# Development: More lenient, Production: Stricter
RATE_LIMIT_MAX_REQUESTS=1000

# Enable/disable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Trusted proxy count (for rate limiting with load balancers)
RATE_LIMIT_TRUST_PROXY=0

# ===============================================
# SHOPIFY INTEGRATION
# ===============================================

# Shopify API credentials (obtain from Shopify Partner Dashboard)
# Leave empty if not using Shopify integration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=

# Shopify store URL (without https://)
# Format: your-store.myshopify.com
SHOPIFY_STORE_URL=

# Shopify webhook secret (for webhook verification)
SHOPIFY_WEBHOOK_SECRET=

# Shopify API version
SHOPIFY_API_VERSION=2023-10

# Enable/disable Shopify sync features
ENABLE_SHOPIFY_SYNC=false

# Shopify sync interval in minutes
SHOPIFY_SYNC_INTERVAL=30

# ===============================================
# EMAIL SERVICE CONFIGURATION
# ===============================================

# Email service provider (sendgrid, mailgun, smtp)
EMAIL_SERVICE=sendgrid

# SendGrid configuration
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Cartaisy

# Mailgun configuration (alternative to SendGrid)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_HOST=api.mailgun.net

# SMTP configuration (alternative email method)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email template IDs (if using service like SendGrid)
EMAIL_TEMPLATE_WELCOME=
EMAIL_TEMPLATE_PASSWORD_RESET=
EMAIL_TEMPLATE_ORDER_CONFIRMATION=

# ===============================================
# FILE STORAGE & CDN
# ===============================================

# File storage provider (local, aws-s3, cloudflare-r2)
FILE_STORAGE_PROVIDER=local

# Local file storage (development default)
FILE_STORAGE_PATH=./uploads
FILE_STORAGE_MAX_SIZE=10485760

# AWS S3 configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# CloudFlare R2 configuration
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# CDN URL for serving static files
CDN_URL=http://localhost:3000/uploads

# ===============================================
# PAYMENT INTEGRATION
# ===============================================

# Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2023-10-16

# PayPal configuration
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ===============================================
# PUSH NOTIFICATIONS
# ===============================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FCM_SENDER_ID=

# Apple Push Notifications (iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=

# Enable/disable push notifications
ENABLE_PUSH_NOTIFICATIONS=false

# ===============================================
# REDIS CONFIGURATION (OPTIONAL)
# ===============================================

# Redis connection (for caching and sessions)
# Leave empty if not using Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis connection options
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_ON_FAILURE=100

# Enable/disable Redis caching
ENABLE_REDIS_CACHE=false

# ===============================================
# LOGGING & MONITORING
# ===============================================

# Log level (error, warn, info, debug)
# Development: debug, Production: info or warn
LOG_LEVEL=debug

# Enable/disable request logging
ENABLE_REQUEST_LOGGING=true

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# New Relic license key (optional)
NEW_RELIC_LICENSE_KEY=

# Application monitoring
ENABLE_PERFORMANCE_MONITORING=false

# ===============================================
# BACKGROUND JOBS & QUEUES
# ===============================================

# Enable/disable background job processing
ENABLE_BACKGROUND_JOBS=true

# Job queue provider (memory, redis, bull)
JOB_QUEUE_PROVIDER=memory

# Job concurrency settings
JOB_CONCURRENCY=2
JOB_MAX_ATTEMPTS=3

# ===============================================
# ANALYTICS & TRACKING
# ===============================================

# Google Analytics tracking ID
GOOGLE_ANALYTICS_ID=

# Enable/disable analytics tracking
ENABLE_ANALYTICS=false

# Custom analytics endpoint
ANALYTICS_ENDPOINT=

# ===============================================
# FEATURE FLAGS
# ===============================================

# Enable/disable specific features for development testing
ENABLE_USER_REGISTRATION=true
ENABLE_GUEST_CHECKOUT=true
ENABLE_PRODUCT_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_MULTI_CURRENCY=false
ENABLE_INVENTORY_TRACKING=true
ENABLE_ORDER_NOTIFICATIONS=true

# ===============================================
# DEVELOPMENT TOOLS
# ===============================================

# Enable/disable development-specific features
ENABLE_API_DOCS=true
ENABLE_GRAPHQL_PLAYGROUND=true
ENABLE_SEED_DATA=true

# Debug modes
DEBUG_DATABASE_QUERIES=false
DEBUG_API_RESPONSES=false
DEBUG_EMAIL_DELIVERY=true

# Mock external services in development
MOCK_SHOPIFY_API=false
MOCK_EMAIL_SERVICE=true
MOCK_PAYMENT_GATEWAY=true

# ===============================================
# DEVELOPMENT SECURITY NOTES
# ===============================================

# 1. Never commit this file with real credentials
# 2. Use .env.local for local overrides (add to .gitignore)
# 3. Generate new JWT secrets for each environment
# 4. Use strong passwords even in development
# 5. Enable HTTPS even in development when possible
# 6. Regularly rotate API keys and secrets
# 7. Use environment-specific database names
# 8. Enable request logging for debugging
# 9. Use mock services to avoid hitting real APIs during development
# 10. Keep development dependencies separate from production

# ===============================================
# VALIDATION REQUIREMENTS
# ===============================================

# Required variables (application will not start without these):
# - NODE_ENV
# - PORT
# - MONGODB_URI
# - JWT_SECRET

# Recommended variables (for full functionality):
# - EMAIL_SERVICE and related credentials
# - FRONTEND_URL
# - CORS_ORIGINS

# Optional variables (enable specific features):
# - SHOPIFY_* (for Shopify integration)
# - REDIS_URL (for caching)
# - FCM_* (for push notifications)
# - STRIPE_* (for payments)
