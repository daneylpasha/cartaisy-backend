								"schema": {
									"$ref": "#/components/schemas/ClearCartResponse"
								}
							}
						}
					},
					"404": {
						"description": "Cart not found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"description": "Clear cart (remove all items)",
				"tags": [
					"Cart"
				],
				"security": [],
				"parameters": [
					{
						"description": "- Shopify cart ID",
						"in": "path",
						"name": "cartId",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
