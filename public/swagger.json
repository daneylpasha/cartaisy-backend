		"/collections/{collectionId}/products": {
			"get": {
				"operationId": "GetCollectionProducts",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/CollectionProductsResponse"
								}
							}
						}
					},
					"400": {
						"description": "Bad Request"
					},
					"404": {
						"description": "Collection not found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				},
				"description": "Get products from a collection with pagination, filtering, and sorting",
				"tags": [
					"Collections"
				],
				"security": [],
				"parameters": [
					{
						"description": "- Shopify collection ID (numeric or GID format)",
						"in": "path",
						"name": "collectionId",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "- Number of products per page (default: 20)",
						"in": "query",
						"name": "limit",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "- Pagination cursor for fetching next page",
						"in": "query",
						"name": "cursor",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "- Sort order for products",
						"in": "query",
						"name": "sortKey",
						"required": false,
						"schema": {
							"$ref": "#/components/schemas/ProductCollectionSortKey"
						}
					},
					{
						"description": "- JSON string of ProductFilter array for filtering products",
						"in": "query",
						"name": "filters",
						"required": false,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
