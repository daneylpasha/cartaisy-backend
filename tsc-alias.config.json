{
  "tsconfigPath": "./tsconfig.json",
  "outDir": "./dist",
  "baseUrl": "./",
  "paths": {
    "@/*": ["src/*"],
    "@/types/*": ["src/types/*"],
    "@/config/*": ["src/config/*"],
    "@/models/*": ["src/models/*"],
    "@/controllers/*": ["src/controllers/*"],
    "@/services/*": ["src/services/*"],
    "@/middleware/*": ["src/middleware/*"],
    "@/utils/*": ["src/utils/*"],
    "@/routes/*": ["src/routes/*"]
  }
}