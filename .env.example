# ============================================================================
# CARTAISY TENANT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and customize for your specific tenant/store
# All values shown are examples - replace with actual values for your deployment

# ============ ENVIRONMENT ============
NODE_ENV=development
PORT=3000

# ============ STORE INFORMATION ============
# Basic store identity and branding
STORE_NAME=Cartaisy Demo Store
STORE_DOMAIN=example.myshopify.com
STORE_LOGO_URL=https://example.com/logo.png
STORE_PRIMARY_COLOR=#4CAF50
STORE_CURRENCY=USD
STORE_TIMEZONE=America/New_York
STORE_COUNTRY=US
STORE_DESCRIPTION=Your premier shopping destination

# ============ API CONFIGURATION ============
# Deployment-specific API settings
API_BASE_URL=https://api.example.com
API_VERSION=v1
FRONTEND_URL=https://app.example.com
ADMIN_EMAIL=admin@example.com

# ============ DATABASE ============
# MongoDB connection string (REQUIRED)
MONGODB_URI=mongodb+srv://daniyal:18August2018@cartaisy-cluster.42lhcjb.mongodb.net/?retryWrites=true&w=majority&appName=cartaisy-cluster
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=1

# ============ SHOPIFY INTEGRATION ============
# Shopify private app credentials (REQUIRED for Shopify stores)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_API_KEY=your_shopify_private_app_key
SHOPIFY_API_SECRET=your_shopify_private_app_secret
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_for_verification
SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_products,write_orders,write_inventory
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_URL=https://your-api-domain.com/api/webhooks
SHOPIFY_ENABLE_SYNC=true
SHOPIFY_SYNC_INTERVAL=4
SHOPIFY_MAX_RETRIES=3
SHOPIFY_RATE_LIMIT_DELAY=1000

# Shopify Storefront API (for mobile app queries)
# In production/SaaS mode, merchant-facing Storefront reads must use store-scoped
# credentials from Store.shopify.storefrontAccessToken. These global credentials
# are only a dev/single-tenant fallback for legacy Storefront callers.
# Set SAAS_MODE=true or MULTI_TENANT_MODE=true to block that fallback outside production.
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_access_token

# ============ EMAIL CONFIGURATION ============
# Email service settings for transactional emails
# Supported providers: 'smtp' (nodemailer), 'resend' (Resend API - recommended)

# Common email settings
EMAIL_FROM_NAME=Cartaisy Team
EMAIL_FROM_ADDRESS=noreply@cartaisy.com
EMAIL_REPLY_TO=support@example.com

# Email service type: 'smtp' or 'resend'
EMAIL_SERVICE_TYPE=resend

# Resend Configuration (recommended - easier setup, better deliverability)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_fGZ5nJjF_DB3uKHrovewPBM4CiMfHG4Hs

# SMTP Configuration (alternative - if using EMAIL_SERVICE_TYPE=smtp)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_SMTP_SECURE=false

# Legacy Email Service API (for other providers)
EMAIL_SERVICE_API_KEY=your_email_service_api_key

# ============ SECURITY ============
# Authentication and security settings (REQUIRED)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-and-random
JWT_EXPIRES_IN=7d
PASSWORD_MIN_LENGTH=6
SESSION_TIMEOUT=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Social Login (Optional)
ENABLE_SOCIAL_LOGIN=false
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Two-Factor Authentication (Optional)
ENABLE_TWO_FACTOR=false

# ============ MOBILE APP CUSTOMIZATION ============
# Mobile app specific settings
APP_NAME=Cartaisy
APP_BUNDLE_ID=com.example.cartaisy
APP_DEEP_LINK_SCHEME=cartaisy
APP_VERSION=1.0.0

# Push Notifications
ENABLE_PUSH_NOTIFICATIONS=true
PUSH_NOTIFICATION_KEY=your_fcm_server_key

# Firebase Cloud Messaging (optional - for push notifications)
