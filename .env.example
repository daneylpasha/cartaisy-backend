# ============================================================================
# CARTAISY TENANT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and customize for your specific tenant/store
# All values shown are examples - replace with actual values for your deployment

# ============ ENVIRONMENT ============
NODE_ENV=development
PORT=3000

# ============ STORE INFORMATION ============
# Basic store identity and branding
STORE_NAME=Cartaisy Demo Store
STORE_DOMAIN=example.myshopify.com
STORE_LOGO_URL=https://example.com/logo.png
STORE_PRIMARY_COLOR=#4CAF50
STORE_CURRENCY=USD
STORE_TIMEZONE=America/New_York
STORE_COUNTRY=US
STORE_DESCRIPTION=Your premier shopping destination

# ============ API CONFIGURATION ============
# Deployment-specific API settings
API_BASE_URL=https://api.example.com
API_VERSION=v1
FRONTEND_URL=https://app.example.com
ADMIN_EMAIL=admin@example.com

# ============ DATABASE ============
# MongoDB connection string (REQUIRED)
MONGODB_URI=mongodb+srv://daniyal:dUCetIVeL@cartaisy-cluster.42lhcjb.mongodb.net/?retryWrites=true&w=majority&appName=cartaisy-cluster
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=1

# ============ SHOPIFY INTEGRATION ============
# Shopify private app credentials (REQUIRED for Shopify stores)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_API_KEY=your_shopify_private_app_key
SHOPIFY_API_SECRET=your_shopify_private_app_secret
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_for_verification
SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_products,write_orders,write_inventory
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_URL=https://your-api-domain.com/api/webhooks
SHOPIFY_ENABLE_SYNC=true
SHOPIFY_SYNC_INTERVAL=4
SHOPIFY_MAX_RETRIES=3
SHOPIFY_RATE_LIMIT_DELAY=1000

# ============ EMAIL CONFIGURATION ============
# Email service settings for transactional emails
EMAIL_FROM_NAME=Cartaisy Team
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_REPLY_TO=support@example.com
EMAIL_SERVICE_TYPE=smtp

# SMTP Configuration (if using EMAIL_SERVICE_TYPE=smtp)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_SMTP_SECURE=false

# Email Service API (if using sendgrid, mailgun, etc.)
EMAIL_SERVICE_API_KEY=your_email_service_api_key

# ============ SECURITY ============
# Authentication and security settings (REQUIRED)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-and-random
JWT_EXPIRES_IN=7d
PASSWORD_MIN_LENGTH=6
SESSION_TIMEOUT=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Social Login (Optional)
ENABLE_SOCIAL_LOGIN=false
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Two-Factor Authentication (Optional)
ENABLE_TWO_FACTOR=false

# ============ MOBILE APP CUSTOMIZATION ============
# Mobile app specific settings
APP_NAME=Cartaisy
APP_BUNDLE_ID=com.example.cartaisy
APP_DEEP_LINK_SCHEME=cartaisy
APP_VERSION=1.0.0

# Push Notifications
ENABLE_PUSH_NOTIFICATIONS=true
PUSH_NOTIFICATION_KEY=your_fcm_server_key

# Analytics
ANALYTICS_TRACKING_ID=UA-XXXXXXXX-1

# ============ SMS NOTIFICATIONS (Optional) ============
ENABLE_SMS_NOTIFICATIONS=false
SMS_SERVICE_PROVIDER=twilio
SMS_SERVICE_API_KEY=your_sms_service_api_key
SMS_SERVICE_API_SECRET=your_sms_service_api_secret
SMS_FROM_NUMBER=+1234567890

# ============ BUSINESS SETTINGS ============
# Store-specific business rules and settings

# Loyalty Program
ENABLE_LOYALTY_PROGRAM=false
LOYALTY_POINTS_RATIO=1.0

# Shipping & Tax
DEFAULT_SHIPPING_RATE=5.99
FREE_SHIPPING_THRESHOLD=50.00
TAX_RATE=0.08
MINIMUM_ORDER_VALUE=10.00
CURRENCY_SYMBOL=$

# Feature Toggles
ENABLE_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_GUEST_CHECKOUT=true

# ============ REDIS CACHING (Optional) ============
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0
REDIS_KEY_PREFIX=cartaisy:

# ============ FILE STORAGE ============
# File upload and storage configuration
STORAGE_PROVIDER=local
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# AWS S3 Storage (if STORAGE_PROVIDER=aws)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ============ PAYMENT PROCESSING ============
# Payment gateway configuration
PAYMENT_DEFAULT_PROVIDER=stripe
ENABLE_MULTIPLE_PAYMENT_PROVIDERS=false

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_SANDBOX=true

# ============ ANALYTICS & MONITORING ============
# Analytics and error tracking
ENABLE_ANALYTICS=true
GOOGLE_ANALYTICS_ID=UA-XXXXXXXX-1
FACEBOOK_PIXEL_ID=your_facebook_pixel_id
HOTJAR_ID=your_hotjar_id

# Error Tracking
ENABLE_ERROR_TRACKING=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============ FEATURE FLAGS ============
# Enable/disable major features per tenant
ENABLE_BLOG=false
ENABLE_CHAT=false
ENABLE_SUBSCRIPTIONS=false
ENABLE_AFFILIATES=false
ENABLE_MULTI_LANGUAGE=false
ENABLE_ADVANCED_SEARCH=false
ENABLE_INVENTORY_TRACKING=true
ENABLE_BACKORDERS=false
ENABLE_SHOPIFY_SYNC=true
ENABLE_PRODUCT_ENHANCEMENT=true
ENABLE_BACKGROUND_JOBS=true

# ============ BACKGROUND JOBS CONFIGURATION ============
# Cron schedules for automated tasks
ENABLE_SCHEDULED_SYNC=true
FULL_SYNC_CRON=0 2 * * *
INCREMENTAL_SYNC_CRON=0 */4 * * *
INVENTORY_SYNC_CRON=*/30 * * * *
ORDER_PROCESSING_CRON=*/15 * * * *
ANALYTICS_UPDATE_CRON=0 * * * *
LOW_STOCK_ALERTS_CRON=0 8 * * *
DATA_CLEANUP_CRON=0 3 * * 0
HEALTH_CHECK_CRON=*/5 * * * *

# ============================================================================
# DEPLOYMENT NOTES:
# ============================================================================
# 
# REQUIRED VARIABLES (Must be set for production):
# - MONGODB_URI
# - JWT_SECRET
# - STORE_NAME
# - EMAIL_FROM_ADDRESS
# - API_BASE_URL
# - FRONTEND_URL
#
# SHOPIFY INTEGRATION (Required for Shopify stores):
# - SHOPIFY_STORE_URL
# - SHOPIFY_API_KEY
# - SHOPIFY_API_SECRET
#
# OPTIONAL BUT RECOMMENDED:
# - EMAIL_SMTP_* (for email functionality)
# - STRIPE_* (for payment processing)
# - PUSH_NOTIFICATION_KEY (for mobile notifications)
#
# SECURITY RECOMMENDATIONS:
# - Use strong, unique JWT_SECRET (minimum 32 characters)
# - Never commit .env file to version control
# - Use different secrets for each environment
# - Enable rate limiting in production
#
# TESTING YOUR CONFIGURATION:
# 1. Copy this file to .env
# 2. Replace placeholder values with real credentials
# 3. Test email sending with your SMTP settings
# 4. Verify database connection with MongoDB URI
# 5. Test API endpoints after starting server
#
# ============================================================================