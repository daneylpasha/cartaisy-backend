# ===============================================
# CARTAISY BACKEND - PRODUCTION ENVIRONMENT
# ===============================================
# CRITICAL: This is the production environment template
# Security is paramount - follow all security guidelines strictly

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment mode - NEVER change this in production
NODE_ENV=production

# Server port - Standard production port behind load balancer
PORT=3000

# Application metadata
APP_NAME=Cartaisy Backend
APP_VERSION=1.0.0

# Production base URL - MUST use HTTPS
BASE_URL=https://api.yourdomain.com

# ===============================================
# DATABASE CONFIGURATION - PRODUCTION
# ===============================================

# MongoDB Atlas production cluster connection
# CRITICAL: Use dedicated production cluster with proper security
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<database>
MONGODB_URI=mongodb+srv://<username>:<password>@<production-cluster-host>/<production-database>?retryWrites=true&w=majority&ssl=true

# Production database connection settings
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Database security settings
MONGODB_AUTH_SOURCE=admin
MONGODB_SSL=true
MONGODB_RETRY_WRITES=true

# Disable debug mode in production
MONGODB_DEBUG=false

# ===============================================
# AUTHENTICATION & SECURITY - PRODUCTION
# ===============================================

# JWT Secret - MUST be cryptographically strong and unique
# Generate: openssl rand -hex 64
# CRITICAL: Store in secure vault, rotate regularly
JWT_SECRET=GENERATE_ULTRA_SECURE_PRODUCTION_JWT_SECRET_MINIMUM_64_CHARS

# Production JWT settings - shorter expiration for security
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# Maximum password hashing for production security
BCRYPT_ROUNDS=15

# Session secret - Must be cryptographically strong
SESSION_SECRET=GENERATE_ULTRA_SECURE_PRODUCTION_SESSION_SECRET

# Additional security settings
JWT_ISSUER=cartaisy-api
JWT_AUDIENCE=cartaisy-clients

# ===============================================
# CORS & FRONTEND CONFIGURATION - PRODUCTION
# ===============================================

# Strict CORS policy for production
# ONLY include your actual production domains
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com

# Production frontend URL
FRONTEND_URL=https://yourdomain.com

# Production mobile app scheme
MOBILE_APP_SCHEME=cartaisy://

# Additional CORS security
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ===============================================
# RATE LIMITING & SECURITY - PRODUCTION
# ===============================================

# Strict rate limiting for production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# Production proxy configuration
RATE_LIMIT_TRUST_PROXY=2

# Additional rate limiting
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# Security headers (all enabled for production)
ENABLE_SECURITY_HEADERS=true
ENABLE_CSRF_PROTECTION=true
ENABLE_XSS_PROTECTION=true
ENABLE_CLICKJACKING_PROTECTION=true

# Content Security Policy
ENABLE_CONTENT_SECURITY_POLICY=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# ===============================================
# SHOPIFY INTEGRATION - PRODUCTION
# ===============================================

# Shopify production store credentials
# CRITICAL: Use production Shopify store only
SHOPIFY_API_KEY=your_production_shopify_api_key
SHOPIFY_API_SECRET=your_production_shopify_api_secret
SHOPIFY_ACCESS_TOKEN=your_production_access_token

# Production Shopify store URL
SHOPIFY_STORE_URL=your-production-store.myshopify.com

# Webhook secret for production
SHOPIFY_WEBHOOK_SECRET=your_production_webhook_secret

# Latest stable API version
SHOPIFY_API_VERSION=2023-10

# Production sync settings
ENABLE_SHOPIFY_SYNC=true
SHOPIFY_SYNC_INTERVAL=60
SHOPIFY_RETRY_ATTEMPTS=3
SHOPIFY_TIMEOUT=30000

# ===============================================
# EMAIL SERVICE - PRODUCTION
# ===============================================

# Production email service
EMAIL_SERVICE=sendgrid

# SendGrid production configuration
SENDGRID_API_KEY=your_production_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Cartaisy

# Production email templates
EMAIL_TEMPLATE_WELCOME=d-production_welcome_template_id
EMAIL_TEMPLATE_PASSWORD_RESET=d-production_reset_template_id
EMAIL_TEMPLATE_ORDER_CONFIRMATION=d-production_order_template_id
EMAIL_TEMPLATE_ORDER_SHIPPED=d-production_shipped_template_id
EMAIL_TEMPLATE_ORDER_DELIVERED=d-production_delivered_template_id

# Email delivery settings
EMAIL_SEND_REAL_EMAILS=true
EMAIL_RETRY_ATTEMPTS=3
EMAIL_QUEUE_ENABLED=true

# ===============================================
# FILE STORAGE & CDN - PRODUCTION
# ===============================================

# Production file storage
FILE_STORAGE_PROVIDER=aws-s3

# AWS S3 production configuration
AWS_ACCESS_KEY_ID=your_production_aws_access_key
AWS_SECRET_ACCESS_KEY=your_production_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cartaisy-production-uploads

# Production CDN configuration
CDN_URL=https://cdn.yourdomain.com

# File security settings
FILE_STORAGE_MAX_SIZE=10485760
FILE_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
FILE_VIRUS_SCANNING=true

# ===============================================
# PAYMENT INTEGRATION - PRODUCTION
# ===============================================

# Stripe production configuration
# CRITICAL: Use only production Stripe keys
STRIPE_SECRET_KEY=sk_live_your_production_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret
STRIPE_API_VERSION=2023-10-16

# PayPal production configuration
PAYPAL_CLIENT_ID=your_production_paypal_client_id
PAYPAL_CLIENT_SECRET=your_production_paypal_client_secret
PAYPAL_MODE=live

# Payment security settings
PAYMENT_WEBHOOK_TOLERANCE=300
PAYMENT_RETRY_ATTEMPTS=3

# ===============================================
# PUSH NOTIFICATIONS - PRODUCTION
# ===============================================

# Firebase production project
FCM_SERVER_KEY=your_production_fcm_server_key
FCM_SENDER_ID=your_production_fcm_sender_id

# Apple Push Notifications production
APNS_KEY_ID=your_production_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_PRIVATE_KEY_PATH=/app/keys/production_apns_private_key.p8

# Production push notification settings
ENABLE_PUSH_NOTIFICATIONS=true
PUSH_NOTIFICATION_BATCH_SIZE=1000
PUSH_NOTIFICATION_RETRY_ATTEMPTS=3

# ===============================================
# REDIS CONFIGURATION - PRODUCTION
# ===============================================

# Redis production cluster
REDIS_URL=redis://production-redis.yourdomain.com:6379
REDIS_PASSWORD=your_ultra_secure_redis_password
REDIS_DB=0

# Redis production settings
REDIS_MAX_RETRIES=5
REDIS_RETRY_DELAY_ON_FAILURE=200
REDIS_CONNECT_TIMEOUT=10000

# Redis security
REDIS_TLS=true
REDIS_AUTH_ENABLED=true

# Enable Redis caching for production
ENABLE_REDIS_CACHE=true
REDIS_CACHE_TTL=3600

# ===============================================
# LOGGING & MONITORING - PRODUCTION
# ===============================================

# Production logging level
LOG_LEVEL=warn

# Production logging settings
ENABLE_REQUEST_LOGGING=false
ENABLE_ERROR_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Sentry production configuration
SENTRY_DSN=your_production_sentry_dsn
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.01

# New Relic production monitoring
NEW_RELIC_LICENSE_KEY=your_production_newrelic_license_key
NEW_RELIC_APP_NAME=Cartaisy Backend Production

# Additional monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1

# ===============================================
# BACKGROUND JOBS - PRODUCTION
# ===============================================

# Production job processing
ENABLE_BACKGROUND_JOBS=true
JOB_QUEUE_PROVIDER=redis

# Production job settings
JOB_CONCURRENCY=8
JOB_MAX_ATTEMPTS=5
JOB_RETRY_DELAY=10000

# Job timeout settings
JOB_TIMEOUT=300000
JOB_STALLED_INTERVAL=30000

# ===============================================
# ANALYTICS & TRACKING - PRODUCTION
# ===============================================

# Google Analytics production property
GOOGLE_ANALYTICS_ID=GA_PRODUCTION_TRACKING_ID

# Production analytics settings
ENABLE_ANALYTICS=true
ANALYTICS_SAMPLE_RATE=1.0

# Custom analytics endpoint
ANALYTICS_ENDPOINT=https://analytics.yourdomain.com

# ===============================================
# FEATURE FLAGS - PRODUCTION
# ===============================================

# Production feature flags (carefully managed)
ENABLE_USER_REGISTRATION=true
ENABLE_GUEST_CHECKOUT=true
ENABLE_PRODUCT_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_MULTI_CURRENCY=true
ENABLE_INVENTORY_TRACKING=true
ENABLE_ORDER_NOTIFICATIONS=true

# Production-only features
ENABLE_ADMIN_DEBUG_MODE=false
ENABLE_TEST_DATA_GENERATION=false

# ===============================================
# SSL & SECURITY - PRODUCTION
# ===============================================

# Force HTTPS in production
FORCE_HTTPS=true
TRUST_PROXY=true

# SSL configuration
SSL_CERT_PATH=/app/ssl/production_cert.pem
SSL_KEY_PATH=/app/ssl/production_key.pem

# Security headers configuration
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Additional security
ENABLE_CONTENT_SECURITY_POLICY=true
ENABLE_REFERRER_POLICY=true
ENABLE_FEATURE_POLICY=true

# ===============================================
# PRODUCTION OPTIMIZATION
# ===============================================

# Disable development features
ENABLE_API_DOCS=false
ENABLE_GRAPHQL_PLAYGROUND=false
ENABLE_SEED_DATA=false

# Production caching
ENABLE_RESPONSE_COMPRESSION=true
ENABLE_ETAG_CACHING=true
CACHE_CONTROL_MAX_AGE=3600

# Request optimization
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# ===============================================
# HEALTH CHECKS - PRODUCTION
# ===============================================

# Production health monitoring
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_PATH=/health
DETAILED_HEALTH_CHECK_PATH=/health/detailed

# Health check security
HEALTH_CHECK_AUTH_REQUIRED=true
HEALTH_CHECK_API_KEY=your_health_check_api_key

# Monitoring intervals
HEALTH_CHECK_INTERVAL=60000
PERFORMANCE_CHECK_INTERVAL=300000

# Production alert thresholds
MEMORY_ALERT_THRESHOLD=90
CPU_ALERT_THRESHOLD=85
RESPONSE_TIME_ALERT_THRESHOLD=1000
ERROR_RATE_ALERT_THRESHOLD=1

# ===============================================
# BACKUP & RECOVERY - PRODUCTION
# ===============================================

# Automated production backups
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_SCHEDULE=0 1 * * *
BACKUP_RETENTION_DAYS=30

# Backup security
BACKUP_ENCRYPTION=true
BACKUP_COMPRESSION=true

# Backup storage
BACKUP_STORAGE_PROVIDER=aws-s3
BACKUP_S3_BUCKET=cartaisy-production-backups
BACKUP_S3_REGION=us-east-1

# Recovery settings
ENABLE_POINT_IN_TIME_RECOVERY=true
RECOVERY_WINDOW_HOURS=72

# ===============================================
# SCALING & PERFORMANCE - PRODUCTION
# ===============================================

# Auto-scaling settings
ENABLE_AUTO_SCALING=true
MIN_INSTANCES=2
MAX_INSTANCES=10
TARGET_CPU_UTILIZATION=70

# Load balancing
ENABLE_LOAD_BALANCING=true
LOAD_BALANCER_ALGORITHM=round_robin

# Connection pooling
DATABASE_POOL_SIZE=50
REDIS_POOL_SIZE=20

# ===============================================
# COMPLIANCE & AUDIT - PRODUCTION
# ===============================================

# Compliance settings
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=365

# GDPR compliance
ENABLE_GDPR_COMPLIANCE=true
DATA_RETENTION_DAYS=730

# PCI compliance (if handling payments)
ENABLE_PCI_COMPLIANCE=true
PCI_LOGGING_LEVEL=detailed

# ===============================================
# PRODUCTION SECURITY CHECKLIST
# ===============================================

# 1. ✓ All secrets are cryptographically strong and unique
# 2. ✓ Database has authentication and SSL enabled
# 3. ✓ All API keys are production-grade
# 4. ✓ Payment gateways use live/production keys
# 5. ✓ SSL certificates are valid and properly configured
# 6. ✓ CORS is restricted to actual production domains
# 7. ✓ Rate limiting is enabled and properly configured
# 8. ✓ All security headers are enabled
# 9. ✓ Logging captures security events without sensitive data
# 10. ✓ Backups are encrypted and regularly tested
# 11. ✓ Monitoring and alerting are configured
# 12. ✓ Access controls are properly implemented
# 13. ✓ Environment variables are stored securely
# 14. ✓ Debug modes are disabled
# 15. ✓ Audit logging is enabled

# ===============================================
# CRITICAL PRODUCTION REQUIREMENTS
# ===============================================

# REQUIRED (application will not start without these):
# - NODE_ENV=production
# - PORT
# - MONGODB_URI (production database with auth)
# - JWT_SECRET (minimum 64 characters, cryptographically secure)
# - BASE_URL (must use HTTPS)

# REQUIRED FOR FULL FUNCTIONALITY:
# - All SHOPIFY_* credentials (production store)
# - EMAIL service configuration (production keys)
# - STRIPE_* credentials (live keys only)
# - AWS_* credentials (production buckets)
# - SSL certificate configuration

# REQUIRED FOR SECURITY:
# - CORS_ORIGINS (restricted to actual domains)
# - Rate limiting configuration
# - Security headers enabled
# - HTTPS enforcement
# - Strong authentication secrets

# ===============================================
# PRODUCTION DEPLOYMENT NOTES
# ===============================================

# 1. Never use development or staging secrets in production
# 2. Store all secrets in secure environment variable management
# 3. Enable all security features and headers
# 4. Use separate infrastructure for production
# 5. Implement proper monitoring and alerting
# 6. Enable automated backups with encryption
# 7. Configure log aggregation and monitoring
# 8. Set up health checks and auto-scaling
# 9. Implement proper CI/CD with security scanning
# 10. Regular security audits and penetration testing
# 11. Disaster recovery plan and testing
# 12. Compliance requirements implementation
# 13. Performance optimization and caching
# 14. Database optimization and indexing
# 15. Regular dependency updates and security patches

# ===============================================
# EMERGENCY CONTACTS & PROCEDURES
# ===============================================

# Production support contacts:
# - DevOps Team: devops@yourdomain.com
# - Security Team: security@yourdomain.com
# - Database Admin: dba@yourdomain.com
# - Application Support: support@yourdomain.com

# Emergency procedures:
# - Security incident: Follow security incident response plan
# - Database issues: Contact DBA team immediately
# - Application errors: Check Sentry and logs, contact dev team
# - Infrastructure issues: Contact DevOps team
