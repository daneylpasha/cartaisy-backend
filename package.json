{
  "name": "cartaisy-backend",
  "packageManager": "yarn@1.22.19",
  "scripts": {
    "build": "npm run generate && tsc --skipLibCheck",
    "build:simple": "rimraf dist && tsc --skipLibCheck --noEmit false --outDir dist --allowJs",
    "build:strict": "tsc && tsc-alias",
    "build:dev": "mkdir -p dist && esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --external:./node_modules/* --external:@* --format=cjs",
    "build:basic": "mkdir -p dist && cp src/server.ts dist/server.js",
    "start": "node --require @swc-node/register -r tsconfig-paths/register src/server.ts",
    "dev": "npm run build && npm start",
    "dev:watch": "nodemon --exec \"npm run generate && ts-node -r tsconfig-paths/register src/server.ts\"",
    "generate": "npm run generate:spec && npm run generate:routes",
    "generate:spec": "tsoa spec",
    "generate:routes": "tsoa routes",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepare": "husky",
    "prepush": "npm run generate:spec && git add public/swagger.json"
  },
  "dependencies": {
    "@shopify/shopify-api": "^11.14.1",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.2",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.5",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.6.0",
    "stripe": "^19.1.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@swc/helpers": "^0.5.17",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "axios": "^1.12.2",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "mongodb-memory-server": "^10.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
